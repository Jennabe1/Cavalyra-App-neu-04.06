# Cavalyra iOS – local signing configuration
#
# Copy this file to ios/.env.local (git-ignored) and fill in the values.
# `scripts/setup-ios-signing.sh` reads it and generates
# `ios/signing.local.xcconfig`, which is auto-included by release.xcconfig.
#
# You get these values from https://developer.apple.com/account
#   - DEVELOPMENT_TEAM:              Membership → Team ID (10 characters)
#   - PROVISIONING_PROFILE_SPECIFIER: Certificates, IDs & Profiles → Profiles
#                                     (the exact name of the App Store profile)

DEVELOPMENT_TEAM=228M5VDU87
PROVISIONING_PROFILE_SPECIFIER=Cavalyra App Store
