<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen API: plain background, no custom icon. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/cavalyra_splash_background</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/cavalyra_splash_background</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
